# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be ignored.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms, you may let them generate their own locks.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#   pdm.lock

# venv
#   Use venv/ or .venv/ as standard directories for python virtual environments.
.venv/
venv/
ENV/
env/

